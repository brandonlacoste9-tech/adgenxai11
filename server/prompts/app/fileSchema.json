{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GeneratedProjectFile",
  "description": "One file in a generated multi-file project.",
  "type": "object",
  "required": ["path", "content"],
  "properties": {
    "path": {
      "type": "string",
      "description": "Unix-style relative path from project root"
    },
    "mode": {
      "type": "string",
      "enum": ["utf-8", "binary"],
      "default": "utf-8"
    },
    "content": {
      "type": "string",
      "description": "Raw file contents"
    }
  },
  "additionalProperties": false
}
